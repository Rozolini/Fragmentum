# --- Rust / Cargo ---
# Ignore the compiled artifacts and build cache
/target/

# --- Project-Specific Test Data ---
# Ignore temporary directories created during end-to-end and integration tests
/temp_cluster/
/temp_storage_test/
/node_*/
*.chunk
*.crc

# --- Environment variables ---
# Ignore local environment files containing secrets or local configs
.env
.env.*

# --- OS Generated Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- IDEs and Editors ---
# JetBrains / IntelliJ
/.idea/
*.iml

# VS Code
/.vscode/*
!/.vscode/settings.json
!/.vscode/tasks.json
!/.vscode/launch.json
!/.vscode/extensions.json

# Eclipse / Others
.project
.classpath
.settings/
*.sublime-workspace

# --- Logs ---
# Ignore application or test crash logs
*.log